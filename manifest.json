{
  "manifest_version": 3,
  "name": "Time Sync - NTP Clock",
  "version": "1.0.2",
  "description": "Synchronize and display accurate time from multiple NTP servers. Perfect for time-sensitive tasks.",
  "author": "A.res.t",
  "homepage_url": "https://github.com/RyuJin-other/",
  "browser_specific_settings": {
    "gecko": {
      "id": "{e8b4c9d2-5f6a-4b31-8c1d-9e7f6a5b4c3d}",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "64": "icons/icons_64.png",
      "32": "icons/icons_32.png",
      "16": "icons/icons_16.png"
    },
    "default_title": "Time Sync - NTP Clock"
  },
  "permissions": ["storage", "geolocation"],
  "host_permissions": [
    "https://worldtimeapi.org/*",
    "https://timeapi.io/*",
    "https://nominatim.openstreetmap.org/*",
    "https://get.geojs.io/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "web_accessible_resources": [
    {
      "resources": ["window.html", "window.js", "src/css/window.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
